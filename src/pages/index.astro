---
import Layout from "../layouts/Layout.astro";
import { facts } from "../data/facts";

const steps = [
  {
    n: "1",
    name: "Create",
    still: "/media/stills/create.jpg",
    alt: "Describing a use case in plain language in the ViewOps AI console",
    head: "Describe the job in plain language.",
    body:
      "You create a use case the way you would brief a new teammate: a few sentences about the goal, the systems, and the rules. The copilot drafts the full working specification. No code, and no integration project.",
  },
  {
    n: "2",
    name: "Govern",
    still: "/media/stills/govern.jpg",
    alt: "The governance editor: mode, approval checkpoints, action allow-list, domain fence",
    head: "The guardrails are the configuration.",
    body:
      "Every use case carries its own governance: an approval checkpoint before anything posts, an explicit allow-list of actions, and a domain fence the agent cannot leave. Guardrails are enforced deterministically, not suggested to the model.",
  },
  {
    n: "3",
    name: "Run",
    still: "/media/stills/run.jpg",
    alt: "A live run drafting a vendor bill in Wave from an invoice in Box",
    head: "It works your real software, live.",
    body:
      "The agent signs in with vaulted credentials it never sees, reads the vendor invoice in Box, and drafts the bill in Wave field by field, matching the total to the penny. It works the same screens your team uses today, and where a system offers an API or a tool, it takes that door under the same governance.",
  },
  {
    n: "4",
    name: "Approve",
    still: "/media/stills/approve.jpg",
    alt: "A parked run waiting in the approval queue",
    head: "It stops by itself. A named human decides.",
    body:
      "Before anything consequential, the run parks and asks. A reviewer sees exactly what was prepared and approves it; only that approved action continues. And in every mode, payment and purchase decisions remain with your people.",
  },
  {
    n: "5",
    name: "Promote",
    still: "/media/stills/autonomous.jpg",
    alt: "An autonomous run creating a vendor record with zero human touches",
    head: "Proven use cases graduate to autonomous.",
    body:
      "Supervised is where a use case starts, not where it ends. When one has earned trust, you promote it: it runs end to end with zero human touches, still inside its fence, still on the audit chain. That is the trust dial.",
  },
  {
    n: "6",
    name: "Prove",
    still: "/media/stills/audit.jpg",
    alt: "The tamper-evident audit chain verified on demand",
    head: "Evidence for every step.",
    body:
      "Every run keeps its outcome, the structured record, and step-by-step visual evidence of what the agent actually did. Every action lands in a tamper-evident audit chain, attributed to a named human or agent identity, verified on demand.",
  },
  {
    n: "7",
    name: "Connect",
    still: "/media/stills/connect.jpg",
    alt: "A governed run calling the payer API directly: one claim auto-filed, one routed to human review",
    head: "Beyond the browser: APIs, data, and MCP.",
    body:
      "Acting on web pages is only one doorway. The agent connects to your APIs, your data, and any system that speaks MCP, under the same fence and allow-list. Two claims, one run: one auto-filed, one routed to review, decided by a policy document your team writes.",
  },
  {
    n: "8",
    name: "Scale",
    still: "/media/stills/scale.jpg",
    alt: "A single autonomous run making 18 governed calls across database, API, MCP, and browser",
    head: "It starts itself, and stays inside the rails.",
    body:
      "Nobody clicks Run. The use case watches the intake feed and sweeps on a schedule. One run, eighteen governed calls across the warehouse, the API, MCP, and a legacy screen, every one fenced, audited, and on the chain.",
  },
];

const useCases = [
  {
    name: "Vendor bill from an invoice",
    route: "Documents to Accounting · supervised",
    body: "Reads a vendor invoice and drafts the bill, line by line. Parks for approval before anything posts.",
  },
  {
    name: "Customer invoice from an SOW",
    route: "Documents to Accounting · supervised",
    body: "Prepares a customer invoice from a statement of work. Parks before sending.",
  },
  {
    name: "Vendor onboarding from a W-9",
    route: "Documents to Accounting · autonomous",
    body: "Turns a W-9 into a finished vendor record with zero human touches. Promoted after proving itself supervised.",
  },
  {
    name: "Claims adjudication against policy",
    route: "Documents + API · autonomous",
    body: "Verifies a claim against the payer API and a versioned policy document. Auto-files what qualifies and routes what does not to review.",
  },
  {
    name: "Claims sweep across four doors",
    route: "Data + API + MCP + Browser · autonomous",
    body: "One governed run, eighteen governed calls: queries the warehouse, verifies members over the API, flags via MCP, works a legacy screen, and delivers the report.",
  },
];

const doors = [
  {
    head: "On screen",
    body: "The interface every system has. If a person can work it on screen, an AI agent can too. No integration project required.",
  },
  {
    head: "APIs",
    body: "Where a system exposes an API, the agent calls it directly: faster, structured, exact. Every call is fenced to approved endpoints, and writes park for approval just like a click.",
  },
  {
    head: "Data and documents",
    body: "Agents query your databases with fenced, read-only access, and produce the documents and spreadsheets your workflows need. Everything stays inside your boundary.",
  },
  {
    head: "MCP tools",
    body: "Agents connect to Model Context Protocol servers, bringing enterprise tools inside your fence. Each MCP tool is allow-listed per use case, and consequential calls park for approval like everything else.",
  },
];

const trust = [
  {
    head: "Sovereign by default",
    body:
      "Everything needed to run an agent runs inside your trust boundary: your VPC or your metal, a self-hosted open model, your data never leaving. No model traffic crosses the boundary unless you explicitly permit it per use case.",
  },
  {
    head: "Credentials the model never sees",
    body:
      "Logins live in an encrypted vault and are injected as masked placeholders at run time. Credential values never reach the model context, the logs, or the artifacts.",
  },
  {
    head: "Your identity provider",
    body:
      "Console access is delegated to your own IdP with enforced role-based access. Approvals are authenticated, so the platform can prove who approved what.",
  },
  {
    head: "Deterministic guardrails",
    body:
      "The approval gate, the action allow-list, the domain fence, and the payment hard stop are enforced in code, outside the model. A clever prompt cannot talk its way past them, whether the agent is clicking a screen or calling an API.",
  },
  {
    head: "Compliance-ready",
    body: facts.compliance,
  },
  {
    head: "Open foundations",
    body:
      "No closed-source runtime dependencies and no per-seat fees. The stack deploys on your Kubernetes, on the clouds you already run.",
  },
];
---

<Layout>
  <!-- Nav -->
  <header class="sticky top-0 z-50 border-b border-ink/10 bg-page/90 backdrop-blur">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
      <a href="/" class="flex shrink-0 items-center gap-2.5 whitespace-nowrap text-lg font-bold text-accent">
        <svg viewBox="0 0 120 120" class="h-7 w-7" aria-hidden="true">
          <rect x="4" y="4" width="112" height="112" rx="26" fill="#5aa9ff"></rect>
          <polyline
            points="33,40 60,92 87,40"
            fill="none"
            stroke="#ffffff"
            stroke-width="14"
            stroke-linecap="round"
            stroke-linejoin="round"></polyline>
          <circle cx="60" cy="24" r="8" fill="#ffffff"></circle>
        </svg>
        {facts.brand}
      </a>
      <nav class="hidden items-center gap-6 text-sm text-mute lg:flex">
        <a href="#doors" class="whitespace-nowrap hover:text-ink">Capabilities</a>
        <a href="#how" class="whitespace-nowrap hover:text-ink">How it works</a>
        <a href="#sovereign" class="whitespace-nowrap hover:text-ink">Sovereignty</a>
        <a href="#use-cases" class="whitespace-nowrap hover:text-ink">Use cases</a>
        <a href="#trust" class="whitespace-nowrap hover:text-ink">Trust</a>
        <a href="#partner" class="whitespace-nowrap hover:text-ink">Design partners</a>
        <a href="/news" class="whitespace-nowrap hover:text-ink">News</a>
      </nav>
      <a
        href="#partner"
        class="hidden whitespace-nowrap rounded-lg bg-accent px-4 py-2 text-sm font-semibold text-white hover:bg-accent-deep lg:inline-block"
        >Talk to us</a
      >
      <details id="mobile-nav" class="relative lg:hidden">
        <summary
          class="flex cursor-pointer list-none items-center rounded-lg border border-ink/15 p-2 text-ink [&::-webkit-details-marker]:hidden"
          aria-label="Menu"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <path d="M4 7h16M4 12h16M4 17h16"></path>
          </svg>
        </summary>
        <nav class="absolute right-0 mt-3 flex w-56 flex-col gap-1 rounded-xl border border-ink/10 bg-page p-3 text-sm shadow-xl">
          <a href="#doors" class="rounded-lg px-3 py-2 text-ink hover:bg-band">Capabilities</a>
          <a href="#how" class="rounded-lg px-3 py-2 text-ink hover:bg-band">How it works</a>
          <a href="#sovereign" class="rounded-lg px-3 py-2 text-ink hover:bg-band">Sovereignty</a>
          <a href="#use-cases" class="rounded-lg px-3 py-2 text-ink hover:bg-band">Use cases</a>
          <a href="#trust" class="rounded-lg px-3 py-2 text-ink hover:bg-band">Trust</a>
          <a href="#partner" class="rounded-lg px-3 py-2 text-ink hover:bg-band">Design partners</a>
          <a href="/news" class="rounded-lg px-3 py-2 text-ink hover:bg-band">News</a>
          <a href="#partner" class="mt-1 rounded-lg bg-accent px-3 py-2 text-center font-semibold text-white hover:bg-accent-deep">Talk to us</a>
        </nav>
      </details>
    </div>
  </header>
  <script>
    document.querySelectorAll("#mobile-nav a").forEach((a) =>
      a.addEventListener("click", () => document.getElementById("mobile-nav")?.removeAttribute("open"))
    );
  </script>

  <!-- Hero -->
  <section class="mx-auto max-w-6xl px-6 pb-16 pt-20 text-center">
    <h1 class="mx-auto max-w-4xl text-4xl font-bold leading-tight sm:text-6xl">
      The governed AI workforce for
      <span class="text-accent">back-office operations</span>
    </h1>
    <p class="mx-auto mt-6 max-w-2xl text-lg text-mute">
      {facts.oneLiner}
    </p>
    <p class="mt-4 text-lg font-semibold text-teal">{facts.trustLine}</p>
    <div class="mx-auto mt-8 flex max-w-3xl flex-wrap items-center justify-center gap-3">
      {
        [
          "Runs in your VPC or on-prem",
          "Self-hosted open model",
          "Your data never leaves",
        ].map((badge) => (
          <span class="rounded-full border border-accent/30 bg-accent/10 px-4 py-1.5 text-sm font-semibold text-accent">
            {badge}
          </span>
        ))
      }
    </div>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
      <a
        href="#video"
        class="rounded-lg bg-accent px-6 py-3 font-semibold text-white hover:bg-accent-deep"
        >Watch the {facts.videoMinutes} demo</a
      >
      <a
        href="#how"
        class="rounded-lg border border-ink/20 px-6 py-3 font-semibold text-ink hover:border-accent hover:text-accent"
        >See how it works</a
      >
    </div>

    <!-- Teaser -->
    <div class="mx-auto mt-12 max-w-4xl overflow-hidden rounded-xl border border-ink/10 shadow-2xl">
      <video
        src={`/media/teaser.mp4?v=${facts.mediaVersion}`}
        autoplay
        muted
        loop
        playsinline
        controls
        class="w-full"
        aria-label="ViewOps AI teaser: a use case is created, runs supervised on live software, is approved by a human, and a promoted use case runs autonomously"
      ></video>
    </div>
    <p class="mt-4 text-sm text-mute">
      {facts.teaserSeconds} preview ·
      <a href="#video" class="font-medium text-accent hover:underline"
        >watch the full {facts.videoMinutes} demo</a
      >
    </p>
    <p class="mx-auto mt-6 max-w-2xl text-sm text-mute">
      {facts.proofClaims.realFootage}
    </p>
    <p class="mx-auto mt-3 max-w-2xl text-sm font-medium text-mute">
      {facts.audienceLine}
    </p>
  </section>

  <!-- Capabilities: every door -->
  <section id="doors" class="border-t border-ink/10 py-20">
    <div class="mx-auto max-w-6xl px-6">
      <h2 class="text-center text-3xl font-bold sm:text-4xl">
        Every door into <span class="text-accent">your systems</span>
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-center text-mute">
        The browser is the universal interface, and it is not the only one. Agents take the best
        door each system offers, and every door passes through the same guardrails: one allow-list,
        one approval gate, one audit chain.
      </p>
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          doors.map((d) => (
            <div class="rounded-xl border border-accent/30 bg-accent/10 p-6">
              <h3 class="text-lg font-bold text-ink">{d.head}</h3>
              <p class="mt-2 text-sm leading-relaxed text-mute">{d.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section id="how" class="border-t border-ink/10 bg-band py-20">
    <div class="mx-auto max-w-6xl px-6">
      <h2 class="text-center text-3xl font-bold sm:text-4xl">How it works</h2>
      <p class="mx-auto mt-4 max-w-2xl text-center text-mute">
        Eight steps from a plain-language description to a measured, audited AI workforce.
      </p>
      <div class="mt-14 space-y-16">
        {
          steps.map((s, i) => (
            <div class={`flex flex-col items-center gap-8 lg:flex-row ${i % 2 ? "lg:flex-row-reverse" : ""}`}>
              <div class="lg:w-1/2">
                <div class="overflow-hidden rounded-xl border border-ink/10 shadow-xl">
                  <img src={s.still} alt={s.alt} loading="lazy" class="w-full" />
                </div>
              </div>
              <div class="lg:w-1/2">
                <div class="text-sm font-bold uppercase tracking-wide text-accent">
                  {s.n} · {s.name}
                </div>
                <h3 class="mt-2 text-2xl font-bold">{s.head}</h3>
                <p class="mt-3 leading-relaxed text-mute">{s.body}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Full video -->
  <section id="video" class="border-t border-ink/10 py-20">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <h2 class="text-3xl font-bold sm:text-4xl">Watch it run, end to end</h2>
      <p class="mx-auto mt-4 max-w-2xl text-mute">
        The {facts.videoMinutes} product video: a use case created by description, governed, run
        live, approved by a named human, promoted to autonomous, connected to APIs, data, and MCP,
        and proven at scale on the audit chain. Filmed on {facts.demoApps}, {facts.demoAppsGloss}.
      </p>
      <div class="mt-10 overflow-hidden rounded-xl border border-ink/10 shadow-2xl">
        <video
          src={`/media/product-video.mp4?v=${facts.mediaVersion}`}
          controls
          preload="metadata"
          poster={`/media/stills/create.jpg?v=${facts.mediaVersion}`}
          class="w-full"></video>
      </div>
    </div>
  </section>

  <!-- Sovereignty -->
  <section id="sovereign" class="border-t border-ink/10 py-20">
    <div class="mx-auto max-w-6xl px-6">
      <h2 class="text-center text-3xl font-bold sm:text-4xl">
        Your environment. Your model. <span class="text-accent">Your data.</span>
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-center text-mute">
        Sovereignty is not a deployment option; it is the default. The four answers your security
        team will ask for first:
      </p>
      <div class="mt-12 grid gap-6 sm:grid-cols-2">
        <div class="rounded-xl border border-ink/10 bg-page p-6">
          <h3 class="text-lg font-bold text-ink">Where does it run?</h3>
          <p class="mt-2 leading-relaxed text-mute">
            Inside your trust boundary: your VPC or your own hardware, deployed on your Kubernetes.
            The agents, the model, the browser, the tools, the data, and the evidence all live
            there.
          </p>
        </div>
        <div class="rounded-xl border border-ink/10 bg-page p-6">
          <h3 class="text-lg font-bold text-ink">Which model?</h3>
          <p class="mt-2 leading-relaxed text-mute">
            A self-hosted open model, served on your GPUs. No calls to a model vendor, no per-seat
            fees, and no closed-source runtime in the stack.
          </p>
        </div>
        <div class="rounded-xl border border-ink/10 bg-page p-6">
          <h3 class="text-lg font-bold text-ink">What leaves the boundary?</h3>
          <p class="mt-2 leading-relaxed text-mute">
            Nothing. Screens, documents, credentials, and model traffic stay inside. Egress is off
            by default and only ever opened per use case, by you, with the change on the audit
            chain.
          </p>
        </div>
        <div class="rounded-xl border border-ink/10 bg-page p-6">
          <h3 class="text-lg font-bold text-ink">Who controls access?</h3>
          <p class="mt-2 leading-relaxed text-mute">
            You do: your identity provider, enforced role-based access, authenticated approvals,
            and a tamper-evident audit chain you can verify and export.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section id="use-cases" class="border-t border-ink/10 bg-band py-20">
    <div class="mx-auto max-w-6xl px-6">
      <h2 class="text-center text-3xl font-bold sm:text-4xl">Real work, on real software</h2>
      <p class="mx-auto mt-4 max-w-2xl text-center text-mute">
        Each of these follows the pattern behind most back-office work: take a document, work the
        system of record, prove the result. Every flow starts supervised, earns its autonomy, and
        is measured: completions, exceptions, and ROI per use case.
      </p>
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          useCases.map((u) => (
            <div class="rounded-xl border border-ink/10 bg-page p-6">
              <div class="text-xs font-semibold uppercase tracking-wide text-accent">{u.route}</div>
              <h3 class="mt-2 text-lg font-bold">{u.name}</h3>
              <p class="mt-2 text-sm leading-relaxed text-mute">{u.body}</p>
            </div>
          ))
        }
        <div class="flex items-center justify-center rounded-xl border border-dashed border-ink/20 p-6 text-center">
          <p class="text-sm text-mute">
            Your back office runs on an ERP, HR, claims, or policy admin system instead? If a
            person can operate it on screen, or it exposes an API, an agent can be taught to.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust -->
  <section id="trust" class="border-t border-ink/10 py-20">
    <div class="mx-auto max-w-6xl px-6">
      <h2 class="text-center text-3xl font-bold sm:text-4xl">Built for the operations you cannot get wrong</h2>
      <p class="mx-auto mt-4 max-w-2xl text-center text-mute">
        Autonomy is only useful if you can adopt it, prove it, and answer for it.
      </p>
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          trust.map((t) => (
            <div class="rounded-xl border border-ink/10 bg-page p-6">
              <h3 class="text-lg font-bold text-ink">{t.head}</h3>
              <p class="mt-2 text-sm leading-relaxed text-mute">{t.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Design partner CTA -->
  <section id="partner" class="border-t border-ink/10 bg-band py-20">
    <div class="mx-auto max-w-5xl px-6 text-center">
      <h2 class="text-3xl font-bold sm:text-4xl">Become a design partner</h2>
      <p class="mx-auto mt-6 max-w-3xl leading-relaxed text-mute">
        We are onboarding a small number of design partners: operations teams in insurance,
        healthcare, financial services, and other regulated back offices. The exchange is simple:
      </p>
      <div class="mt-10 grid gap-6 text-left sm:grid-cols-3">
        <div class="rounded-xl border border-ink/10 bg-page p-6">
          <div class="text-sm font-bold uppercase tracking-wide text-accent">You bring</div>
          <p class="mt-2 text-sm leading-relaxed text-mute">
            One high-volume, rules-driven workflow your team runs on screen today, and the software
            it runs on.
          </p>
        </div>
        <div class="rounded-xl border border-ink/10 bg-page p-6">
          <div class="text-sm font-bold uppercase tracking-wide text-accent">We deliver</div>
          <p class="mt-2 text-sm leading-relaxed text-mute">
            Hands-on deployment inside your boundary and your first use cases built with you,
            supervised from day one, measured from the first run.
          </p>
        </div>
        <div class="rounded-xl border border-ink/10 bg-page p-6">
          <div class="text-sm font-bold uppercase tracking-wide text-accent">You get</div>
          <p class="mt-2 text-sm leading-relaxed text-mute">
            Direct influence on the roadmap and founding-customer terms that stay with you as the
            platform grows.
          </p>
        </div>
      </div>
      <a
        href={`mailto:${facts.contactEmail}?subject=ViewOps%20AI%20design%20partner`}
        class="mt-10 inline-block rounded-lg bg-accent px-8 py-4 text-lg font-semibold text-white hover:bg-accent-deep"
        >Talk to us: {facts.contactEmail}</a
      >
      <p class="mt-4 text-sm text-mute">
        The first step is a short note: the workflow, the software it runs on, and roughly how many
        times a month your team does it. That is enough for a first conversation.
      </p>
    </div>
  </section>

  <!-- Footer -->
  <footer class="border-t border-ink/10 py-10">
    <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 px-6 text-sm text-mute sm:flex-row">
      <div>
        <span class="font-bold text-accent">{facts.brand}</span>
        · governed AI agents, sovereign execution
      </div>
      <div>© 2026 {facts.brand} · {facts.domain}</div>
    </div>
  </footer>
</Layout>
